---
const nav = [
  { href: '/articles', label: 'Articles' },
  { href: '/notes', label: 'Notes' },
  { href: '/resources', label: 'Resources' },
  { href: '/about', label: 'About' },
];
---

<header class="w-full px-6 py-10 flex items-center justify-between">
  <a
    href="/"
    class="font-serif text-xl tracking-tight text-neutral-900 hover:text-neutral-600"
  >
    Shilima-Wonfon
  </a>
  <nav class="flex items-center gap-8">
    {
      nav.map(({ href, label }) => (
        <a
          href={href}
          class="font-sans text-sm text-neutral-600 hover:text-neutral-900"
        >
          {label}
        </a>
      ))
    }
  </nav>
</header>
