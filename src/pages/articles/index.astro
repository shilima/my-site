---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const articles = (
  await getCollection('articles', ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Articles · Shilima-Wonfon">
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-32">
    <header class="mb-20">
      <p
        class="font-sans text-xs uppercase tracking-[0.25em] text-neutral-500 mb-6"
      >
        Writing
      </p>
      <h1
        class="font-serif font-light text-4xl md:text-5xl text-neutral-900 leading-tight tracking-tight"
      >
        Articles
      </h1>
    </header>

    {
      articles.length === 0 ? (
        <p class="font-serif text-neutral-500">No articles yet.</p>
      ) : (
        <div>
          {articles.map((entry) => (
            <PostCard
              title={entry.data.title}
              description={entry.data.description}
              href={`/articles/${entry.id}`}
              pubDate={entry.data.pubDate}
              lang={entry.data.lang}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
