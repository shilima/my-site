---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const today = new Date();
const isoDate = today.toISOString();
const dateStr = isoDate.slice(0, 10);

const [articles, notes, resources] = await Promise.all([
  getCollection('articles'),
  getCollection('notes'),
  getCollection('resources'),
]);

const latestNote = [...notes].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)[0];

function splitParagraphs(body: string): string[] {
  return body
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter((line) => line.length > 0 && line !== '---');
}

const previewLines = latestNote ? splitParagraphs(latestNote.body) : [];

const stats = [
  { label: 'Articles', value: articles.length },
  { label: 'Notes', value: notes.length },
  { label: 'Resources', value: resources.length },
];
---

<BaseLayout title="Shilima-Wonfon">
  <header
    slot="header"
    class="w-full px-6 py-5 flex items-center justify-between gap-6"
  >
    <div
      class="font-sans text-xs text-neutral-500 tracking-wide flex items-center gap-2"
    >
      <span class="text-base font-medium text-neutral-900">Reinventing</span>
      <span class="text-neutral-300">|</span>
      <span>@wonfon</span>
      <span class="text-neutral-300">·</span>
      <time datetime={isoDate}>{dateStr}</time>
    </div>

    <nav class="flex items-center gap-6 font-sans text-xs tracking-wide">
      <a href="/articles" class="text-neutral-600 hover:text-neutral-900"
        >Articles</a
      >
      <a href="/notes" class="text-neutral-600 hover:text-neutral-900">Notes</a>
      <a href="/resources" class="text-neutral-600 hover:text-neutral-900"
        >Resources</a
      >
      <a href="/about" class="text-neutral-600 hover:text-neutral-900">About</a>
    </nav>

    <button
      type="button"
      class="font-sans text-sm text-neutral-700 border border-neutral-300 px-4 py-1.5 hover:text-neutral-900 hover:border-neutral-900"
    >
      Sign In
    </button>
  </header>

  <section class="mx-auto max-w-3xl px-6 pt-32 pb-8">
    <h1
      class="font-serif font-light text-neutral-900 text-4xl md:text-5xl leading-[1.1] tracking-tight mb-8"
    >
      A New Journey After Sixty
    </h1>

    <p
      class="font-serif italic text-xl md:text-2xl text-neutral-600 leading-relaxed mb-12"
    >
      Still learning, still building, still becoming.
    </p>

    <section class="space-y-3">
      <p class="font-serif text-2xl text-neutral-900">Shilima-Wonfon</p>
      <p class="font-serif text-lg text-neutral-700">逆风的孤影</p>
      <p class="font-sans text-sm text-neutral-500">
        Structural Engineer · Runner · Investor
      </p>
    </section>

    {
      latestNote && (
        <section class="mt-32">
          <p class="font-sans text-xs uppercase tracking-[0.25em] text-neutral-500 mb-8">
            Latest Note
          </p>
          <h2 class="font-serif font-light text-2xl md:text-3xl text-neutral-900 leading-tight mb-6">
            <a
              href={`/notes/${latestNote.id}`}
              class="hover:text-neutral-600"
            >
              {latestNote.data.title}
            </a>
          </h2>
          <div
            class="mb-8"
            style="position: relative; max-height: 7.5rem; overflow: hidden;"
          >
            <div class="font-serif text-base md:text-lg text-neutral-600 leading-relaxed">
              {previewLines.map((line, i) => (
                <p class={i > 0 ? 'mt-3' : ''}>{line}</p>
              ))}
            </div>
            <div
              style="position: absolute; bottom: 0; left: 0; right: 0; height: 4rem; background: linear-gradient(to bottom, transparent 0%, rgba(255,255,255,0.7) 50%, white 100%); pointer-events: none;"
            />
          </div>
          <a
            href={`/notes/${latestNote.id}`}
            class="font-sans text-xs uppercase tracking-[0.2em] text-neutral-700 hover:text-neutral-900 border-b border-neutral-400 hover:border-neutral-900 pb-1"
          >
            阅读全文 →
          </a>
        </section>
      )
    }

    <dl class="grid grid-cols-3 gap-8 mt-32 pt-12 border-t border-neutral-200">
      {
        stats.map(({ label, value }) => (
          <div>
            <dt class="font-sans text-xs uppercase tracking-[0.2em] text-neutral-500 mb-3">
              {label}
            </dt>
            <dd class="font-serif font-light text-xl md:text-2xl text-neutral-700">
              {value}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>
</BaseLayout>
