---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const [articles, notes, resources] = await Promise.all([
  getCollection('articles'),
  getCollection('notes'),
  getCollection('resources'),
]);

const stats = [
  { label: 'Articles', value: articles.length },
  { label: 'Notes', value: notes.length },
  { label: 'Resources', value: resources.length },
];
---

<BaseLayout title="Shilima-Wonfon">
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-32">
    <p
      class="font-sans text-xs uppercase tracking-[0.25em] text-neutral-500 mb-14"
    >
      Hello
    </p>

    <h1
      class="font-serif font-light text-neutral-900 text-4xl md:text-5xl leading-[1.1] tracking-tight mb-20"
    >
      Shilima-Wonfon
    </h1>

    <p
      class="font-serif text-xl md:text-2xl text-neutral-700 leading-relaxed mb-40"
    >
      逆风的孤影
    </p>

    <blockquote
      class="font-serif italic text-2xl md:text-3xl text-neutral-800 leading-[1.5] border-l border-neutral-300 pl-8 my-24"
    >
      A New Journey After Sixty
    </blockquote>

    <dl
      class="grid grid-cols-3 gap-8 mt-32 pt-12 border-t border-neutral-200"
    >
      {
        stats.map(({ label, value }) => (
          <div>
            <dt class="font-sans text-xs uppercase tracking-[0.2em] text-neutral-500 mb-3">
              {label}
            </dt>
            <dd class="font-serif font-light text-2xl md:text-3xl text-neutral-700">
              {value}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>
</BaseLayout>
